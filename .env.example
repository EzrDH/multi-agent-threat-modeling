# =============================================================================
# Environment Variables Template
# =============================================================================
# Salin file ini menjadi .env (tanpa .example) dan isi dengan kredensial kamu
# JANGAN commit file .env ke Git!
# =============================================================================

# --- Google Gemini API ---
# Dapatkan di: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSyBgrZEtU-YnY8TfXSN23Rj6hG9cs7HGHIc

# --- Model Configuration ---
# Model yang digunakan untuk agent reasoning
# Pilihan: gemini-2.5-flash (cepat, gratis), gemini-2.5-pro (lebih akurat, kuota lebih kecil)
GEMINI_MODEL=gemini-2.5-flash

# --- LLM Behavior ---
# Temperature: 0.0 = deterministik, 1.0 = kreatif
# Untuk threat modeling, gunakan rendah (0.2-0.4) agar konsisten
LLM_TEMPERATURE=0.3

# --- Logging ---
# Level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# --- Output ---
# Direktori untuk menyimpan hasil threat modeling
OUTPUT_DIR=./outputs
